{
    "name": "default",
    "vendor": "inox",
    "version": "1.0.0",
    "description": "Default theme for INOX CMS — clean, minimal, responsive.",
    "settings": [
        { "key": "primary_color", "type": "color",   "default": "#3b82f6",  "label": "Brand Color" },
        { "key": "secondary_color", "type": "color", "default": "#10b981",  "label": "Secondary Color" },
        { "key": "font_body",     "type": "select",  "default": "Inter",
          "options": ["Inter", "Roboto", "Merriweather", "Lora", "Open Sans"], "label": "Body Font" },
        { "key": "hero_layout",   "type": "select",  "default": "fullscreen",
          "options": ["fullscreen", "boxed", "minimal"],                     "label": "Hero Style" },
        { "key": "show_sidebar",  "type": "boolean", "default": true,        "label": "Show Sidebar" },
        { "key": "footer_text",   "type": "text",    "default": "",          "label": "Footer Note" },
        { "key": "logo",          "type": "media",   "default": "",           "label": "Site Logo" }
    ],
    "templates": ["layout", "home", "page", "post", "archive", "search", "404"],
    "download_url": "https://github.com/maicolrme/inoxcms-themes/archive/refs/tags/inox-default/v1.0.0.zip",
    "assets": {
        "css": ["assets/css/app.css"]
    }
}
