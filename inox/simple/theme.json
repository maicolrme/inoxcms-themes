{
    "name": "simple",
    "vendor": "inox",
    "version": "1.0.0",
    "description": "A minimal, clean blog-style theme — the homepage shows the latest posts, perfect for content-focused sites.",
    "settings": [
        { "key": "primary_color", "type": "color", "default": "#2563eb", "label": "Brand Color" },
        { "key": "show_home_posts", "type": "boolean", "default": true, "label": "Show latest posts on homepage" },
        { "key": "footer_text", "type": "text", "default": "", "label": "Footer Note" }
    ],
    "templates": ["layout", "home", "page", "post", "archive", "search", "404"],
    "download_url": "https://github.com/maicolrme/inoxcms-themes/archive/refs/tags/inox-simple/v1.0.0.zip",
    "assets": {
        "css": ["assets/css/app.css"]
    }
}
